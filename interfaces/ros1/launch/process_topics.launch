<launch>
  <arg name="sensor_config"/>
  <arg name="params" default="params"/>
  <arg name="rviz" default="false"/>
  <!-- The node reads the YAML config-file paths from its command-line arguments
       (not the ROS parameter server), so they are passed via args=. An absolute
       path (starting with '/') is used verbatim so configs can live in an
       external folder; otherwise the arg is a name (without .yaml) looked up in
       the package's config/ directory. -->
  <node pkg="bievr_lio_ros" type="process_topics" name="bievr_lio_topics_node" output="screen"
        args="$(eval '--sensor_config_file ' + (arg('sensor_config') if arg('sensor_config').startswith('/') else find('bievr_lio_ros') + '/../../config/sensor_configs/' + arg('sensor_config') + '.yaml') + ' --params_file ' + (arg('params') if arg('params').startswith('/') else find('bievr_lio_ros') + '/../../config/' + arg('params') + '.yaml'))"/>

  <group if="$(arg rviz)">
    <node launch-prefix="nice" pkg="rviz" type="rviz" name="rviz" args="-d $(find bievr_lio_ros)/rviz/config.rviz" />
  </group>
</launch>